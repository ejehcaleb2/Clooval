{
  "name": "cloova",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
  "dev": "tsx backend/server.ts",
  "dev:frontend": "cd frontend && vite",
  "dev:backend": "tsx backend/server.ts",
  "db:import": "node scripts/import_to_pg.cjs",
  "build:frontend": "cd frontend && vite build --outDir ../dist-frontend",
  "build:backend": "esbuild backend/server.ts --bundle --platform=node --format=cjs --sourcemap --outfile=dist-backend/server.cjs",
  "build": "npm run build:frontend && npm run build:backend",
  "start": "node dist-backend/server.cjs",
  "preview": "vite preview --config frontend/vite.config.ts",
  "clean": "rm -rf dist dist-backend dist-frontend cloova_db.json",
  "lint": "tsc --noEmit",
  "generate-vapid": "node scripts/generate-vapid.mjs"
},
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@sendgrid/mail": "^8.1.6",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.11.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
